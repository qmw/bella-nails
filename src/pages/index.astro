---
import Layout from '../layouts/Layout.astro';

const navLinks = [
  { href: "#o-studiu", label: "O studiu" },
  { href: "#uslugi", label: "Usługi" },
  { href: "#cennik", label: "Cennik" },
  { href: "#galeria", label: "Galeria" },
  { href: "#opinie", label: "Opinie" },
  { href: "#rezerwacja", label: "Rezerwacja" },
  { href: "#kontakt", label: "Kontakt" },
];

const services = [
  {
    icon: "💅",
    name: "Manicure Hybrydowy",
    desc: "Trwałe wykończenie do 3 tygodni. Idealny kolor, perfekcyjny błysk, niezawodna trwałość dla aktywnych kobiet.",
    tag: "HIT",
    color: "from-pink-50 to-rose-50",
    accent: "#d6336c",
  },
  {
    icon: "✨",
    name: "Manicure Żelowy",
    desc: "Budowanie i wzmacnianie płytki. Naturalne lub ekstrawaganckie długości — Twój wybór, nasza precyzja.",
    tag: "Bestseller",
    color: "from-purple-50 to-pink-50",
    accent: "#b794d4",
  },
  {
    icon: "🌸",
    name: "Pedicure",
    desc: "Luksusowa pielęgnacja stóp z peelinger, maską nawilżającą i hybrydowym wykończeniem. Spa dla Twoich stóp.",
    tag: "Relaks",
    color: "from-rose-50 to-peach-50",
    accent: "#f7b2c4",
  },
  {
    icon: "🎨",
    name: "Stylizacja i Zdobienia",
    desc: "Nail art, folia holograficzna, kamyczki, wzory ręcznie malowane. Każdy paznokieć to małe dzieło sztuki.",
    tag: "Unikat",
    color: "from-fuchsia-50 to-purple-50",
    accent: "#d6336c",
  },
];

const prices = [
  {
    category: "Manicure",
    items: [
      { name: "Manicure hybrydowy", price: "130 zł" },
      { name: "Manicure hybrydowy + zdobienie", price: "150–190 zł" },
      { name: "Manicure żelowy (budowanie)", price: "170 zł" },
      { name: "Manicure żelowy + forma", price: "190 zł" },
      { name: "Zdjęcie hybrydy / żelu", price: "30 zł" },
      { name: "Uzupełnienie żelu", price: "140 zł" },
    ],
  },
  {
    category: "Pedicure",
    items: [
      { name: "Pedicure klasyczny", price: "110 zł" },
      { name: "Pedicure hybrydowy", price: "140 zł" },
      { name: "Pedicure SPA (maska + masaż)", price: "170 zł" },
      { name: "Pedicure medyczny", price: "150 zł" },
    ],
  },
  {
    category: "Zdobienia i Dodatki",
    items: [
      { name: "Nail art (1 paznokieć)", price: "10–30 zł" },
      { name: "Folia holograficzna", price: "20 zł" },
      { name: "Kamyczki / kryształki Swarovski", price: "15–40 zł" },
      { name: "Ombre / gradient", price: "30 zł" },
      { name: "French / baby boomer", price: "20 zł" },
    ],
  },
];

const gallery = [
  { url: "https://images.unsplash.com/photo-1604654894610-df63bc536371?auto=format&fit=crop&w=600&q=80", alt: "Manicure hybrydowy w kolorze różowym" },
  { url: "https://images.unsplash.com/photo-1604654894610-df63bc536371?auto=format&fit=crop&w=600&q=80", alt: "Stylizacja żelowa z kamieniami" },
  { url: "https://images.unsplash.com/photo-1604902396830-aca29e19b067?auto=format&fit=crop&w=600&q=80", alt: "Nail art z kwiatami" },
  { url: "https://images.unsplash.com/photo-1604654894610-df63bc536371?auto=format&fit=crop&w=600&q=80", alt: "Ombre różowo-fioletowe" },
  { url: "https://images.unsplash.com/photo-1604902396830-aca29e19b067?auto=format&fit=crop&w=600&q=80", alt: "French manicure nowoczesny" },
  { url: "https://images.unsplash.com/photo-1604654894610-df63bc536371?auto=format&fit=crop&w=600&q=80", alt: "Pedicure SPA — stopy" },
  { url: "https://images.unsplash.com/photo-1604902396830-aca29e19b067?auto=format&fit=crop&w=600&q=80", alt: "Zdobienia holograficzne" },
  { url: "https://images.unsplash.com/photo-1604654894610-df63bc536371?auto=format&fit=crop&w=600&q=80", alt: "Budowanie żelowe naturalne" },
  { url: "https://images.unsplash.com/photo-1604902396830-aca29e19b067?auto=format&fit=crop&w=600&q=80", alt: "Kryształki Swarovski" },
];

const reviews = [
  {
    name: "Karolina W.",
    stars: 5,
    text: "Absolutnie zachwycona! Przychodę tu od roku i nigdy się nie zawiodłam. Asia robi cuda z paznokciami — precyzja i kreatywność na najwyższym poziomie. Studio jest prześliczne, a atmosfera sprawia, że chce się wracać.",
    date: "Kwiecień 2025",
    service: "Manicure hybrydowy",
  },
  {
    name: "Monika R.",
    stars: 5,
    text: "Najlepsze studio paznokci w Warszawie! Pedicure SPA to prawdziwy relaks — maska, masaż, piękne wykończenie. Już umówiłam się na kolejną wizytę. Polecam każdej kobiecie, która chce poczuć się wyjątkowo.",
    date: "Marzec 2025",
    service: "Pedicure SPA",
  },
  {
    name: "Aleksandra P.",
    stars: 5,
    text: "Przyszłam po nail art na wesele i wyszłam z czegoś, o czym marzyłam — ręcznie malowane kwiatki z kryształkami. Gościki pytały mnie przez cały wieczór gdzie byłam. Bella Nails to artyzm!",
    date: "Maj 2025",
    service: "Stylizacja i zdobienia",
  },
  {
    name: "Natalia K.",
    stars: 5,
    text: "Świetne studio, wspaniałe Panie i realistyczne ceny jak na taką jakość. Żel idealnie leży już 4 tygodnie bez odchodzenia. Stałam się stałą klientką i polecam wszystkim znajomym.",
    date: "Luty 2025",
    service: "Manicure żelowy",
  },
];

const team = [
  { name: "Asia Kowalczyk", role: "Właścicielka & Head Nail Artist", exp: "8 lat doświadczenia", cert: "Certyfikat CND, Shellac Master" },
  { name: "Kasia Nowak", role: "Senior Nail Artist", exp: "5 lat doświadczenia", cert: "Nail Art Champion 2023" },
  { name: "Marta Zielińska", role: "Nail Artist & Pedicure Specialist", exp: "4 lata doświadczenia", cert: "Pedicure medyczny, SPA" },
];
---

<Layout title="Bella Nails — Studio Paznokci Warszawa | Manicure Hybrydowy i Żelowy">

  <!-- NAVIGATION -->
  <header id="nav" class="fixed left-0 right-0 z-50 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 lg:h-18">
        <!-- Logo -->
        <a href="#" class="flex items-center gap-2 group">
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#d6336c] to-[#b794d4] flex items-center justify-center text-white text-xs font-bold" style="font-family: var(--font-display)">BN</div>
          <span class="font-bold text-[#2e1f29] text-lg tracking-tight" style="font-family: var(--font-display)">Bella <span class="text-[#d6336c]">Nails</span></span>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-6">
          {navLinks.map(link => (
            <a href={link.href} class="text-sm font-500 text-[#7a5a6a] hover:text-[#d6336c] transition-colors duration-200" style="font-family: var(--font-body)">{link.label}</a>
          ))}
        </nav>

        <!-- CTA + Burger -->
        <div class="flex items-center gap-3">
          <a href="#rezerwacja" class="btn-primary hidden lg:inline-flex">
            <span>Umów wizytę</span>
          </a>
          <button id="burger" class="lg:hidden p-2 text-[#2e1f29] hover:text-[#d6336c] transition-colors" aria-label="Menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden lg:hidden bg-[#fdf7fa] border-t border-[#f0dae5] shadow-lg">
      <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-3">
        {navLinks.map(link => (
          <a href={link.href} class="text-sm font-500 text-[#2e1f29] hover:text-[#d6336c] transition-colors py-2 border-b border-[#f0dae5]" style="font-family: var(--font-body)">{link.label}</a>
        ))}
        <a href="#rezerwacja" class="btn-primary mt-2 justify-center">
          <span>Umów wizytę</span>
        </a>
      </div>
    </div>
  </header>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center overflow-hidden bg-[#fdf7fa]">
    <!-- Background shapes -->
    <div class="absolute inset-0 z-0">
      <div class="absolute top-0 right-0 w-2/3 h-full bg-gradient-to-bl from-[#fce4ef] via-[#fdf0f5] to-transparent"></div>
      <div class="absolute bottom-0 left-0 w-1/3 h-1/2 bg-gradient-to-tr from-[#f9d4e6] to-transparent opacity-50"></div>
      <!-- Decorative circles -->
      <div class="absolute top-20 right-20 w-64 h-64 rounded-full bg-gradient-to-br from-[#f7b2c4] to-[#b794d4] opacity-10 blur-3xl"></div>
      <div class="absolute bottom-40 left-10 w-48 h-48 rounded-full bg-[#d6336c] opacity-8 blur-2xl"></div>
      <!-- Pattern dots -->
      <div class="absolute top-32 left-1/4 w-3 h-3 rounded-full bg-[#d6336c] opacity-30"></div>
      <div class="absolute top-60 left-1/3 w-2 h-2 rounded-full bg-[#b794d4] opacity-40"></div>
      <div class="absolute bottom-60 right-1/4 w-4 h-4 rounded-full bg-[#f7b2c4] opacity-50"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full pt-32 pb-20 lg:py-0">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center min-h-screen lg:min-h-0 lg:py-24">
        <!-- Text -->
        <div class="flex flex-col gap-6">
          <div class="inline-flex items-center gap-2 bg-white border border-[#f0dae5] rounded-full px-4 py-2 w-fit shadow-sm">
            <span class="w-2 h-2 rounded-full bg-[#d6336c] animate-pulse"></span>
            <span class="text-xs font-600 text-[#7a5a6a] tracking-wide" style="font-family: var(--font-body)">Studio paznokci • Warszawa, Mokotów</span>
          </div>

          <h1 style="font-family: var(--font-display)" class="text-4xl sm:text-5xl lg:text-6xl font-700 text-[#2e1f29] leading-tight">
            Twoje paznokcie,<br/>
            <span class="shimmer-text">Twój styl.</span>
          </h1>

          <p class="text-lg text-[#7a5a6a] max-w-lg leading-relaxed" style="font-family: var(--font-body); font-weight: 400;">
            Wyjątkowe studio paznokci w sercu Mokotowa. Manicure hybrydowy i żelowy, pedicure SPA, artystyczne zdobienia — perfekcja w każdym szczególe.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mt-2">
            <a href="#rezerwacja" class="btn-primary"><span>Umów wizytę online</span></a>
            <a href="#uslugi" class="btn-outline">Zobacz usługi</a>
          </div>

          <!-- Stats -->
          <div class="flex gap-8 mt-4 pt-6 border-t border-[#f0dae5]">
            <div>
              <div class="text-2xl font-700 text-[#d6336c]" style="font-family: var(--font-display)">5+</div>
              <div class="text-xs text-[#7a5a6a] mt-0.5" style="font-family: var(--font-body)">lat na rynku</div>
            </div>
            <div>
              <div class="text-2xl font-700 text-[#d6336c]" style="font-family: var(--font-display)">2000+</div>
              <div class="text-xs text-[#7a5a6a] mt-0.5" style="font-family: var(--font-body)">zadowolonych klientek</div>
            </div>
            <div>
              <div class="text-2xl font-700 text-[#d6336c]" style="font-family: var(--font-display)">4.9★</div>
              <div class="text-xs text-[#7a5a6a] mt-0.5" style="font-family: var(--font-body)">średnia ocena</div>
            </div>
          </div>
        </div>

        <!-- Hero Image -->
        <div class="relative flex justify-center lg:justify-end">
          <div class="relative w-full max-w-lg">
            <!-- Floating badge 1 -->
            <div class="absolute -top-4 -left-4 z-20 bg-white rounded-2xl shadow-lg px-4 py-3 float-anim">
              <div class="flex items-center gap-2">
                <span class="text-2xl">💅</span>
                <div>
                  <div class="text-xs font-700 text-[#2e1f29]" style="font-family: var(--font-display)">Hybryd</div>
                  <div class="text-xs text-[#7a5a6a]">od 130 zł</div>
                </div>
              </div>
            </div>

            <!-- Main image -->
            <div class="relative rounded-3xl overflow-hidden shadow-2xl aspect-[4/5] bg-gradient-to-br from-[#f9d4e6] to-[#e8c5d8]">
              <img
                src="https://images.unsplash.com/photo-1604654894610-df63bc536371?auto=format&fit=crop&w=800&q=80"
                alt="Piękny manicure Bella Nails"
                class="w-full h-full object-cover"
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#2e1f29]/30 via-transparent to-transparent"></div>
            </div>

            <!-- Floating badge 2 -->
            <div class="absolute -bottom-4 -right-4 z-20 bg-[#d6336c] text-white rounded-2xl shadow-lg px-4 py-3">
              <div class="text-xs font-700" style="font-family: var(--font-display)">Wolne terminy</div>
              <div class="text-xs opacity-90">Już od jutra!</div>
            </div>

            <!-- Decorative ring -->
            <div class="absolute -inset-4 rounded-3xl border-2 border-[#f7b2c4]/40 -z-10"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 opacity-60">
      <span class="text-xs text-[#7a5a6a]" style="font-family: var(--font-body)">Przewiń w dół</span>
      <div class="w-0.5 h-8 bg-gradient-to-b from-[#d6336c] to-transparent animate-pulse"></div>
    </div>
  </section>

  <!-- O STUDIU -->
  <section id="o-studiu" class="py-20 lg:py-28 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-[#f9d4e6] opacity-30 blur-3xl -z-10"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Images grid -->
        <div class="relative reveal">
          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-4">
              <div class="rounded-2xl overflow-hidden bg-[#f9d4e6] aspect-square shadow-lg">
                <img src="https://images.unsplash.com/photo-1560066984-138dadb4c035?auto=format&fit=crop&w=500&q=80" alt="Wnętrze studia Bella Nails" class="w-full h-full object-cover"/>
              </div>
              <div class="rounded-2xl overflow-hidden bg-[#f9d4e6] aspect-video shadow-lg">
                <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?auto=format&fit=crop&w=500&q=80" alt="Narzędzia do manicure" class="w-full h-full object-cover"/>
              </div>
            </div>
            <div class="space-y-4 pt-8">
              <div class="rounded-2xl overflow-hidden bg-[#f9d4e6] aspect-video shadow-lg">
                <img src="https://images.unsplash.com/photo-1604902396830-aca29e19b067?auto=format&fit=crop&w=500&q=80" alt="Stylizacja paznokci" class="w-full h-full object-cover"/>
              </div>
              <div class="rounded-2xl overflow-hidden bg-[#f9d4e6] aspect-square shadow-lg">
                <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?auto=format&fit=crop&w=500&q=80" alt="Gotowy manicure" class="w-full h-full object-cover"/>
              </div>
            </div>
          </div>
          <!-- Award badge -->
          <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 bg-gradient-to-r from-[#d6336c] to-[#b794d4] text-white rounded-full px-6 py-3 shadow-lg whitespace-nowrap">
            <span class="text-sm font-600" style="font-family: var(--font-display)">✦ Top Studio Mokotów 2024</span>
          </div>
        </div>

        <!-- Text -->
        <div class="reveal reveal-delay-2">
          <div class="inline-block bg-[#fce4ef] text-[#d6336c] text-xs font-700 tracking-widest uppercase px-4 py-2 rounded-full mb-6" style="font-family: var(--font-display)">
            O nas
          </div>
          <h2 class="section-title text-3xl lg:text-4xl mb-6 leading-tight" style="font-family: var(--font-display)">
            Pasja do piękna<br/><span class="text-[#d6336c]">w każdym detalu</span>
          </h2>
          <p class="text-[#7a5a6a] leading-relaxed mb-4" style="font-family: var(--font-body)">
            Bella Nails to więcej niż salon — to miejsce, gdzie sztuka spotyka się z perfekcją. Od 2019 roku tworzymy wyjątkowe stylizacje dla kobiet, które cenią jakość i oryginalność.
          </p>
          <p class="text-[#7a5a6a] leading-relaxed mb-8" style="font-family: var(--font-body)">
            Nasz zespół doświadczonych artystek paznokci stale podnosi kwalifikacje, korzystając wyłącznie z profesjonalnych produktów najwyższej klasy. Każda wizyta to rytuał pielęgnacji i chwila tylko dla Ciebie.
          </p>

          <!-- Features -->
          <div class="grid grid-cols-2 gap-4 mb-8">
            {[
              { icon: "🌿", text: "Produkty premium" },
              { icon: "🔬", text: "Pełna sterylizacja" },
              { icon: "🎓", text: "Ciągłe szkolenia" },
              { icon: "💝", text: "Indywidualne podejście" },
            ].map(feat => (
              <div class="flex items-center gap-3 bg-white rounded-xl p-3 border border-[#f0dae5] shadow-sm">
                <span class="text-xl">{feat.icon}</span>
                <span class="text-sm font-500 text-[#2e1f29]" style="font-family: var(--font-body)">{feat.text}</span>
              </div>
            ))}
          </div>

          <!-- Team -->
          <div class="space-y-3">
            {team.map(member => (
              <div class="flex items-center gap-4 bg-[#fff8fb] rounded-xl p-4 border border-[#f0dae5]">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[#d6336c] to-[#b794d4] flex items-center justify-center text-white font-700 text-sm flex-shrink-0" style="font-family: var(--font-display)">
                  {member.name.charAt(0)}
                </div>
                <div class="min-w-0">
                  <div class="font-600 text-[#2e1f29] text-sm" style="font-family: var(--font-body)">{member.name}</div>
                  <div class="text-xs text-[#7a5a6a]">{member.role} · {member.exp}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- USŁUGI -->
  <section id="uslugi" class="py-20 lg:py-28 bg-pink-gradient relative overflow-hidden">
    <div class="absolute inset-0 opacity-40" style="background-image: radial-gradient(circle at 20% 80%, #f7b2c4 0%, transparent 50%), radial-gradient(circle at 80% 20%, #b794d4 0%, transparent 50%);"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-16 reveal">
        <div class="inline-block bg-white text-[#d6336c] text-xs font-700 tracking-widest uppercase px-4 py-2 rounded-full mb-6 shadow-sm" style="font-family: var(--font-display)">
          Usługi
        </div>
        <h2 class="section-title text-3xl lg:text-4xl mb-4" style="font-family: var(--font-display)">
          Czym się zajmujemy
        </h2>
        <p class="text-[#7a5a6a] max-w-xl mx-auto" style="font-family: var(--font-body)">
          Od klasycznych stylizacji po zaawansowany nail art — oferujemy pełen zakres usług dla pięknych, zdrowych paznokci.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map((svc, i) => (
          <div class={`service-card bg-white rounded-3xl p-6 border border-[#f0dae5] shadow-sm reveal reveal-delay-${i + 1}`}>
            <!-- Tag -->
            <div class="flex justify-between items-start mb-4">
              <span class="text-4xl">{svc.icon}</span>
              <span class="text-xs font-700 px-3 py-1 rounded-full" style={`background: ${svc.accent}20; color: ${svc.accent}; font-family: var(--font-display)`}>
                {svc.tag}
              </span>
            </div>
            <h3 class="font-700 text-[#2e1f29] text-lg mb-3 leading-tight" style="font-family: var(--font-display); font-size: 1rem">{svc.name}</h3>
            <p class="text-sm text-[#7a5a6a] leading-relaxed mb-6" style="font-family: var(--font-body)">{svc.desc}</p>
            <a href="#cennik" class="text-sm font-600 text-[#d6336c] hover:underline flex items-center gap-1" style="font-family: var(--font-body)">
              Zobacz cennik →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CENNIK -->
  <section id="cennik" class="py-20 lg:py-28 relative">
    <div class="absolute bottom-0 left-0 w-80 h-80 rounded-full bg-[#b794d4] opacity-10 blur-3xl -z-10"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
